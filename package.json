{
  "name": "cloud-engineering-learning-os",
  "version": "0.1.0",
  "private": true,
  "description": "Cloud Engineering Learning Operating System — an interactive learning platform for cloud engineering",
  "scripts": {
    "docusaurus": "docusaurus",
    "dev": "docusaurus start",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,mdx,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,mdx,css}\"",
    "test": "echo \"Tests configured — add test suites\" && exit 0",
    "validate": "npm run typecheck && npm run format:check",
    "preview": "npm run build && npm run serve"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.2",
    "@docusaurus/faster": "3.10.2",
    "@docusaurus/plugin-content-docs": "3.10.2",
    "@docusaurus/plugin-content-pages": "3.10.2",
    "@docusaurus/plugin-ideal-image": "3.10.2",
    "@docusaurus/plugin-pwa": "3.10.2",
    "@docusaurus/preset-classic": "3.10.2",
    "@docusaurus/theme-mermaid": "3.10.2",
    "@docusaurus/theme-search-algolia": "3.10.2",
    "@easyops-cn/docusaurus-search-local": "^0.48.0",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.2",
    "@docusaurus/tsconfig": "3.10.2",
    "@docusaurus/types": "3.10.2",
    "@types/react": "^19.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "typescript": "~6.0.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
