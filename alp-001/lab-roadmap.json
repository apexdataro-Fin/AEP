{
  "version": "1.0.0",
  "alp_id": "alp-001",
  "description": "ALP-001 Lab Roadmap — 8 lab types with full progression from guided to career-immersive labs. Every lab maps to modules, skills, and career activities.",
  "total_labs": 40,
  "lab_types": {
    "guided": {
      "id": "guided",
      "description": "Step-by-step labs with complete instructions. Learner follows along to build confidence.",
      "when_to_use": "When introducing new technology or concept",
      "difficulty_range": "beginner",
      "count": 12,
      "modules": ["01-foundations", "02-linux", "05-python", "06-cloud-fundamentals", "13-git"]
    },
    "challenge": {
      "id": "challenge",
      "description": "Goal given, minimal instructions. Learner must figure out implementation.",
      "when_to_use": "After guided labs, to build independence",
      "difficulty_range": "beginner to intermediate",
      "count": 10,
      "modules": ["03-networking", "09-docker", "14-github", "15-cicd", "20-monitoring"]
    },
    "production": {
      "id": "production",
      "description": "Real-world production scenarios. Learner applies skills to production-like environments.",
      "when_to_use": "When learner is ready for production-grade work",
      "difficulty_range": "intermediate to advanced",
      "count": 8,
      "modules": ["07-azure-core", "10-kubernetes", "12-terraform", "18-gitops"]
    },
    "debugging": {
      "id": "debugging",
      "description": "Broken systems. Learner must diagnose and fix issues. Root cause analysis required.",
      "when_to_use": "To build troubleshooting and incident-response skills",
      "difficulty_range": "intermediate to advanced",
      "count": 5,
      "modules": ["02-linux", "03-networking", "10-kubernetes", "21-observability"]
    },
    "security": {
      "id": "security",
      "description": "Security-focused labs: hardening, penetration testing mindset, vulnerability remediation.",
      "when_to_use": "Building security-first engineering habits",
      "difficulty_range": "intermediate to advanced",
      "count": 4,
      "modules": ["04-security", "17-devsecops", "23-identity"]
    },
    "architecture": {
      "id": "architecture",
      "description": "Design challenges. Learner designs architecture, gets it reviewed, iterates.",
      "when_to_use": "Building architectural thinking",
      "difficulty_range": "advanced",
      "count": 3,
      "modules": ["19-platform", "30-ai-infra", "31-portfolio"]
    },
    "ai": {
      "id": "ai",
      "description": "AI-focused labs: prompt engineering, model deployment, RAG, agents, evaluation.",
      "when_to_use": "For AI/ML track modules",
      "difficulty_range": "intermediate to expert",
      "count": 5,
      "modules": ["24-azure-ai", "25-vector-db", "26-rag", "27-ai-agents"]
    },
    "career": {
      "id": "career",
      "description": "Career-immersive labs: simulated workday, incident response, architecture review, mock interview.",
      "when_to_use": "To bridge learning and real-world work",
      "difficulty_range": "all",
      "count": 3,
      "modules": ["32-interview", "33-career"]
    }
  },
