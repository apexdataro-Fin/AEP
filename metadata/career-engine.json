        "deliverables": ["string"],
        "portfolio_value": "low | medium | high",
        "review_criteria": ["string"]
      }
    },
    "architecture_reviews": {
      "description": "Architecture Decision Records (ADR) and review scenarios",
      "schema": {
        "id": "string",
        "title": "string",
        "context": "string",
        "decision": "string",
        "alternatives_considered": ["string"],
        "consequences": "string",
