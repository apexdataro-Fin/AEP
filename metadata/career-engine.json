      }
    },
    "performance_reviews": {
      "description": "Simulated performance review scenarios",
      "schema": {
        "id": "string",
        "career_level": "string",
        "scenario": "string",
        "strengths": ["string"],
        "growth_areas": ["string"],
        "action_items": ["string"],
        "promotion_readiness": "boolean"
      }
    }
