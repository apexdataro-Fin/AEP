    "plugin_system": {
      "description": "Plugins are self-contained modules that can be enabled/disabled per domain or globally.",
      "interface": {
        "register": "Function to register plugin components, routes, and settings",
        "lifecycle": ["onInit", "onEnable", "onDisable", "onUpdate"],
        "hooks": ["navigation", "search", "dashboard", "analytics", "content"]
      }
    }
  }
