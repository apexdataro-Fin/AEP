    { "id": "interactive-lab", "label": "Interactive Labs", "icon": "🧪" },
    { "id": "certification", "label": "Certifications", "icon": "📜" },
    { "id": "career-track", "label": "Career Tracks", "icon": "👔" },
    { "id": "knowledge-base", "label": "Knowledge Base", "icon": "🧠" },
    { "id": "university", "label": "Universities", "icon": "🏛️" },
