{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apexdataro-fin.github.io/AEP/schemas/extended-metadata.schema.json",
  "title": "Extended Content Metadata Schema",
  "description": "Complete AI-friendly metadata schema for all learning content. Supports the full Learning Core with AI integration, review scheduling, certification mapping, and knowledge graph connections.",
  "type": "object",
  "required": ["id", "title", "slug", "summary", "difficulty"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Unique machine-readable identifier (kebab-case)"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "slug": {
      "type": "string",
      "pattern": "^/[a-z0-9-]+(/[a-z0-9-]+)*$"
    },
    "content_type": {
      "type": "string",
      "enum": [
        "lesson",
        "mini-lesson",
        "lab",
        "project",
        "simulator",
        "certification-lesson",
        "career-lesson",
        "interview-lesson",
        "architecture-review",
        "production-incident",
        "decision-lab",
        "troubleshooting-guide",
        "reference",
        "glossary-entry",
        "cheat-sheet",
        "technology-overview"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 20,
      "maxLength": 280,
      "description": "AI-friendly one-paragraph summary"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 160,
      "description": "SEO meta description"
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced", "expert", "architect"]
    },
    "estimated_time": {
      "type": "object",
      "properties": {
        "minutes": { "type": "integer", "minimum": 1 },
        "hours": { "type": "number", "minimum": 0.25 },
        "display": { "type": "string", "description": "Human-readable: '25 min', '2.5 hours'" }
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "published", "deprecated", "archived"]
    },
    "author": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "last_updated": { "type": "string", "format": "date" },
    "technologies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "category": { "type": "string" },
          "proficiency_required": {
            "type": "string",
            "enum": ["none", "basic", "intermediate", "advanced"]
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/skillRef" }
    },
    "learning_levels": {
      "type": "object",
      "description": "Five explanation layers: Simple, Core, Professional, Production, Architect",
      "properties": {
        "has_simple": { "type": "boolean", "default": true },
        "has_core": { "type": "boolean", "default": true },
        "has_professional": { "type": "boolean", "default": false },
        "has_production": { "type": "boolean", "default": false },
        "has_architect": { "type": "boolean", "default": false }
      }
    },
    "prerequisites": {
      "type": "array",
      "items": { "$ref": "#/$defs/contentRef" }
    },
    "depends_on": {
      "type": "array",
      "items": { "$ref": "#/$defs/contentRef" },
      "description": "Hard dependencies — must be completed first"
    },
    "related_lessons": { "type": "array", "items": { "$ref": "#/$defs/contentRef" } },
    "related_projects": { "type": "array", "items": { "$ref": "#/$defs/contentRef" } },
    "related_labs": { "type": "array", "items": { "$ref": "#/$defs/contentRef" } },
    "related_simulators": { "type": "array", "items": { "$ref": "#/$defs/contentRef" } },
    "certifications": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "enum": ["AZ-900", "AZ-104", "AZ-400", "AI-102", "AZ-500", "DP-900", "SC-900"]
          },
          "objective_id": { "type": "string" },
          "weight": { "type": "integer", "minimum": 1, "maximum": 5 }
        }
      }
    },
    "career_relevance": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "role": { "type": "string" },
          "level": { "type": "string", "enum": ["junior", "mid", "senior", "lead", "principal"] },
          "importance": { "type": "integer", "minimum": 1, "maximum": 5 }
        }
      }
    },
    "knowledge_nodes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Knowledge graph node IDs this content relates to"
    },
    "learning_objectives": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string", "minLength": 10 },
          "category": { "type": "string", "enum": ["knowledge", "skill", "attitude", "behavior"] },
          "bloom_level": {
            "type": "string",
            "enum": ["remember", "understand", "apply", "analyze", "evaluate", "create"]
          }
        },
        "required": ["id", "description"]
      }
    },
    "active_recall": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "question": { "type": "string" },
          "answer": { "type": "string" },
          "hint": { "type": "string" },
          "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] }
        },
        "required": ["question", "answer"]
      }
    },
    "feynman_points": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Key concepts explained in simplest possible terms (Feynman Technique)"
    },
    "review_schedule": {
      "type": "object",
      "properties": {
        "intervals_days": {
          "type": "array",
          "items": { "type": "integer" },
          "description": "Spaced repetition intervals: [1, 3, 7, 14, 30, 90]"
        },
        "priority": { "type": "string", "enum": ["low", "normal", "high", "critical"] },
        "retention_target": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
    },
    "search_keywords": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Additional search terms"
    },
    "interview_topics": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Interview topics this content prepares for"
    },
    "production_topics": {
      "type": "array",
      "items": { "type": "string" }
    },
    "security_topics": {
      "type": "array",
      "items": { "type": "string" }
    },
    "cost_topics": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ai_topics": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "contentRef": {
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["slug"]
    },
    "skillRef": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "proficiency": {
          "type": "string",
          "enum": ["awareness", "basic", "intermediate", "advanced", "expert"]
        }
      },
      "required": ["id"]
    }
  }
}
